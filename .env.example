# Root directory where Pits n' Giggles stores telemetry data.
# The app will recursively scan for .json files under this path.
TELEMETRY_DIR=/Users/you/Library/CloudStorage/OneDrive-Personal

# Optional local-only debug corpus. Useful when you have generated or downloaded
# throwaway telemetry for QA; keep real paths in your uncommitted .env.
# DEBUG_TELEMETRY_DIR=/Users/you/path/to/debug-telemetry

# Optional: override the product name for embedded builds.
# VITE_APP_NAME="F1 Save Viewer"

# Optional: serve/build the app under a non-root base path, e.g. when it's mounted
# behind a reverse proxy or embedded under another app's routes. Affects both the
# built asset URLs and the client-side router basename. Defaults to "/".
# VITE_BASE_PATH="/save-viewer/"

# Optional: poll interval (seconds) for refreshing the session list in the browser
# (standalone/dev use — when embedded in Pits n' Giggles, this is configured
# via the app's own settings instead). Unset or 0 disables polling; the
# session list still refreshes when the tab regains focus. Defaults to disabled.
# VITE_SESSION_POLL_INTERVAL_S=10
