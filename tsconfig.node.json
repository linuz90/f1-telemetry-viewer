{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "scripts/dev-port.ts",
    "scripts/dev-server-port.ts",
    "src/plugin/**/*",
    "src/utils/parseFilename.ts"
  ]
}
