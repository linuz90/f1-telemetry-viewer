{
  "name": "f1-telemetry-viewer",
  "version": "0.1.0",
  "description": "Web app for visualizing F1 sim racing telemetry from Pits n' Giggles",
  "author": "linuz90",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "pnpm": ">=10.26.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:port": "tsx scripts/dev-port.ts",
    "dev:telemetry": "tsx scripts/dev-with-telemetry.ts",
    "dev:debug": "tsx scripts/dev-debug-telemetry.ts",
    "dev:prod": "vite --mode devprod",
    "build": "tsc && vite build",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "preview": "vite preview",
    "generate-demo": "npx tsx scripts/generate-demo-data.ts",
    "find-session": "bash scripts/find-session.sh",
    "start": "tsx server.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "prettier": "3.8.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.6.0"
  }
}
